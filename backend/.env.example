# =============================================
# JobBot AI - Backend Environment Variables
# Copy to .env and fill in your values
# =============================================

# Supabase (supabase.com → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Resend (resend.com → API Keys)
RESEND_API_KEY=re_YOUR_API_KEY_HERE
FROM_EMAIL=jobbot@yourdomain.com

# Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google Custom Search (Module A web job discovery — optional)
# See README setup: Cloud API key + Programmable Search Engine ID (cx)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# API auth — must match Vercel JOBBOT_ACCESS_SECRET (never expose in NEXT_PUBLIC_*)
X_JOBBOT_KEY=choose_a_long_random_secret

# Where users open the dashboard from email links
# Local:    http://localhost:3000
# Prod:     https://your-frontend-domain.vercel.app
DASHBOARD_URL=http://localhost:3000

# CORS — comma-separated frontend URLs (no trailing slash)
# Local: http://localhost:3000
# Prod:  https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# App
PORT=8000
ENVIRONMENT=development
