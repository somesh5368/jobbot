# Frontend Environment Variables
# Local: copy to .env.development (or .env.local)
# Prod:  set in Vercel → Project Settings → Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Must end with /api — backend routes are under /api/*
# Local:  http://localhost:8000/api
# Prod:   https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Must match backend X_JOBBOT_KEY (sent as X-JobBot-Key header)
NEXT_PUBLIC_UI_ACCESS_KEY=choose_a_long_random_secret
