# =============================================
# JobBot Frontend — Environment Variables
# =============================================
# Copy to .env.local for local dev (never commit .env.local)
#
# PUBLIC (safe in browser — Supabase anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# SERVER-ONLY (Vercel + .env.local — never use NEXT_PUBLIC_ for these)
# Must match backend X_JOBBOT_KEY on Render exactly
JOBBOT_ACCESS_SECRET=choose_a_long_random_secret

# Backend URL for the Next.js API proxy (must end with /api)
# Local:  http://localhost:8000/api
# Prod:   https://your-backend.onrender.com/api
BACKEND_API_URL=http://localhost:8000/api
